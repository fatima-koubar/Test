 public List<Pos> GetPosFiltered(Dictionary<string, string> filters)  
 {
     PosDAO posDAO = new();
     List<Pos> posList = new List<Pos>();

     List<PosDb> posDTOList = posDAO._context.Pos
     .Include(p => p.environment)
     .Include(p => p.infrastructure)
     .Include(p => p.language)
     .Include(p => p.payment_method)
     .Where(p => p.persoId == filters["persoId"] && p.idEnvironment.ToString() == filters["environment"] && p.idInfrastructure.ToString() == filters["infrastructure"] 
     && p.idPaymentMethod.ToString() == filters["paymentMethod"])
     .ToList();

     posDTOList.ForEach(pos => {
         Pos p = (Pos)pos;
         posList.Add(p);
     });

     return posList;
 }
