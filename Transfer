<script>
const items = [
  ["component-apple", "apple"],
  ["component-banana", "banana"],
  ["component-ananas", "ananas"]
];

let index = 0;

window.addEventListener("paymentGenerated", () => {
  index++;

  if (index < items.length) {
    const [component, type] = items[index];
    paymentComponent.generate(component, type);
  }
});

function startGeneration() {
  const [component, type] = items[index];
  paymentComponent.generate(component, type);
}

// Exemple : quand generate est terminé quelque part
function onPaymentFinished() {
  window.dispatchEvent(new Event("paymentGenerated"));
}

startGeneration();
</script>
