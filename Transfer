      .subscribe(result => {
        if (!result || result.action !== 'add') return;

        const basePos = {
          ...result.pos,
          persoId: this.persoId,
          idPaymentMethod: result.pos.paymentMethod,
          idLanguage: 4,
          id: 0
        };
        const infrastructures = this._posListService.getInfrastructures(basePos.infrastructure);
        const environments = [1, 2];

        let alreadyExists = false;

        const requests = infrastructures.flatMap(infra => {

          if (this._posListService.isPosExist(this.posListData(), basePos, infra)) {
            alreadyExists = true;
            return [];
          }

          return environments.map(env => ({
            ...basePos,
            idInfrastructure: infra,
            idEnvironment: env
          }));
        });

        if (alreadyExists) {
          this._posListService.showPOSAlreadyExistSnackBar();
        }

        if (requests.length === 0) return;

        from(requests).pipe(
          mergeMap(pos =>
            this._posExtService.postPos(pos)
          ),
          takeUntilDestroyed(this._destroyRef)
        ).subscribe({
          next: () => {},
          complete: () => this.updateData()
        });
      });
  }

