import { NgElement, WithProperties } from '@angular/elements';
import { environment } from 'src/environments/environment';

export interface TranslationsPayload {
  iFrameTitle: string;
  iFramePopinTitle: string;
}

export class PaymentComponent extends EventTarget {
  type: string = '';

  private translations?: TranslationsPayload

  constructor(private _paymentSessionId: string) {
    super();
  }

  generate(id: string, paymentMeanType?: string): void {
    if (!id.match('^[A-Za-z]+[\\w\\-\\:\\.]*$')) {
      throw new Error("'id' is not a valid HTML id attribute");
    }
    const paymentComponent = document.createElement('pc-payment-component') as NgElement & WithProperties<{ paymentSessionId: string, title: string }>;
    paymentComponent.style.width = '100%';
    paymentComponent.style.height = '0';
    paymentComponent.paymentSessionId = this._paymentSessionId;
    let iframePopin: NgElement;
    const wrapper = document.getElementById(id);
    if (wrapper) {
      wrapper.appendChild(paymentComponent);
      let acceptedEmitters : Window[] = [];
      const iframeContent = (paymentComponent.getElementsByTagName("iframe")[0] as HTMLIFrameElement).contentWindow;
      acceptedEmitters.push(iframeContent!);
      window.addEventListener('message', (event) => {
        if (acceptedEmitters.findIndex(x => x === event.source) === -1) {
          return;
        }
        switch (event.data.action) {
          case 'ready':
            console.log("ready received");
            if (paymentMeanType) {
              const iframeBis = document.getElementById('pc-iframe') as HTMLIFrameElement;
              const url = environment.moneticoUrl + '/payment-component/payment-session/' + this._paymentSessionId + '/' + paymentMeanType;
              iframeBis.src = url;
            }
              // iframeContent?.postMessage({ action: 'sendPaymentMeanType', paymentMeanType: paymentMeanType ?? undefined }, "*");
            break;
        }
      });
    }
  }
}
export class PaymentComponents {
  private _paymentSessionId: string | undefined;

  initialize(paymentSessionId: string): void {
    if (paymentSessionId.match('^[a-fA-F0-9]{8}-([a-fA-F0-9]{4}-){3}[a-fA-F0-9]{12}|[a-fA-F0-9]{32}$')) {
      this._paymentSessionId = paymentSessionId;
    }
    else {
      throw new Error("'paymentSessionId' is not a valid UUID");
    }
  }

  createComponent(): PaymentComponent {
    if (!this._paymentSessionId) {
      throw new Error("'initialize' method was not called before creating component");
    }
    return new PaymentComponent(this._paymentSessionId);
  }

}


