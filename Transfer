import {
  Component,
  ElementRef,
  OnInit,
  Signal,
  ViewContainerRef,
  WritableSignal,
  computed,
  inject,
  input,
  output,
  signal,
  viewChild,
} from '@angular/core';
import { TranslatePipe } from '@ngx-translate/core';
import { ApplePayComponent } from '../../../apple-pay/components/apple-pay.component';
import { CardComponent } from '../../../card/components/card/card.component';
import { InvisibleIframe } from '../../../card/components/invisible-iframe/invisible-iframe.component';
import { PaymentMeanData, PaymentMeanPipe } from '../../../core';
import { UrlService } from '../../../core/services/url.service';
import {
  ExternalRedirection,
  Hateoas,
  HateoasPaymentMean,
  HateoasPaymentMeanApplePay,
  HateoasPaymentMeanPaymentInitiation,
  INTEGRATION_TYPES,
  PAYMENT_MEAN_TYPES,
  PaymentMean,
  PaymentMeanType,
  RECOMMENDED_IMPLEMENTATIONS,
  Redirection,
  createPaymentMean,
} from '../../../domain';
import { PaymentInitiationComponent } from '../../../payment-initiation/components/payment-initiation/payment-initiation.component';
import { PaypalButtonComponent } from '../../../paypal/components/button/button.component';
import { SpinnerService } from '../../../spinner/spinner.service';
import { WeroButtonComponent } from '../../../wero/component/button/button.component';
import { rgbaToHslAndAdjust } from '../../utils/color-conversion.utils';
import { PaymentMeanService } from '../../payment-mean.service';
import { PAYMENT_SESSION_CONTEXT } from '../../../../public-api';
import { CommonModule } from '@angular/common';

@Component({
  selector: 'pc-payment-mean',
  templateUrl: './payment-mean.component.html',
  styleUrls: ['./payment-mean.component.scss'],
  standalone: true,
  imports: [
    PaymentInitiationComponent,
    CardComponent,
    InvisibleIframe,
    PaymentMeanPipe,
    TranslatePipe,
    PaypalButtonComponent,
    ApplePayComponent,
    WeroButtonComponent,
    CommonModule,
  ],
})
export class PaymentMeanComponent implements OnInit {
  readonly data = input.required<PaymentMeanData>();
  readonly links = input.required<Hateoas>();
  readonly paymentSessionId = input.required<string>();
  readonly hateoasLinks: WritableSignal<Hateoas> = signal<Hateoas>({} as Hateoas);
  readonly generatedPaymentMean = input<string | null | undefined>();

  readonly nextStepEvent = output<Redirection>();

  private readonly _service = inject(PaymentMeanService);
  private readonly _spinnerService = inject(SpinnerService);
  protected readonly _urlService = inject(UrlService);
  private readonly _integrationType = inject(PAYMENT_SESSION_CONTEXT);

  private readonly _alreadySubmitted = signal<boolean>(false);
  readonly selectedPaymentMean = signal<PaymentMean | undefined>(undefined);
  readonly showInvisibleIframe = signal<boolean>(false);
  readonly isReady = signal<boolean>(false);

  readonly paymentMeans: WritableSignal<PaymentMean[]> = signal<PaymentMean[]>([]);
  readonly paymentSessionHref: WritableSignal<string> = signal<string>('');

  readonly container = viewChild.required('overlay', { read: ViewContainerRef });
  readonly paymentMeanButton = viewChild.required('paymentMeanButton', {
    read: ElementRef<HTMLButtonElement>,
  });

  readonly backgroundColor: Signal<string> = computed(() => {
    const button = this.paymentMeanButton().nativeElement;
    return window.getComputedStyle(button).backgroundColor;
  });

  readonly hoverColor = signal<string>('');

  readonly PaymentMeanType = PAYMENT_MEAN_TYPES;

  async ngOnInit(): Promise<void> {
    const isPaymentComponent = this._integrationType === INTEGRATION_TYPES.PAYMENT_COMPONENT;

    if (isPaymentComponent && this.generatedPaymentMean()) {
      const filteredPaymentMean = this.getPaymentMeanByWrapperId(this.generatedPaymentMean());
      this.hateoasLinks.set(filteredPaymentMean);
    } else {
      this.hateoasLinks.set(this.links());
    }
    await this.initiate();
    setTimeout(() => {
      this.hoverColor.set(rgbaToHslAndAdjust(this.backgroundColor()));
    });
  }

  private async initiate(): Promise<void> {
    this.paymentMeans.set(
      (this.hateoasLinks().paymentMeans ?? []).map((pm) =>
        createPaymentMean(this.getPaymentMeanProps(pm)),
      ),
    );

    this.paymentSessionHref.set(this.hateoasLinks().self.href);

    await this._service.applePayloadScript(this.paymentMeans(), this.links());
    if (this.paymentMeans().length === 1) {
      this.selectedPaymentMean.set(this.paymentMeans().at(0));
    }
    this.isReady.set(true);
  }

  private getPaymentMeanByWrapperId(paymentMeanType: string | null | undefined) {
    return {
      ...this.links(),
      asProps: this.links().asProps,
      paymentMeans: !paymentMeanType
        ? []
        : this.links().paymentMeans?.filter((pm) => pm.type === paymentMeanType),
    };
  }

  private getPaymentMeanProps(hateoasPaymentMean: HateoasPaymentMean) {
    const basePaymentMean = {
      type: hateoasPaymentMean.type,
      href: hateoasPaymentMean.href,
    };

    if (hateoasPaymentMean instanceof HateoasPaymentMeanPaymentInitiation) {
      return {
        ...basePaymentMean,
        sctType: hateoasPaymentMean.sctType,
      };
    }
    if (hateoasPaymentMean instanceof HateoasPaymentMeanApplePay) {
      return {
        ...basePaymentMean,
        merchantIdentifier: hateoasPaymentMean.merchantIdentifier,
      };
    }
    return basePaymentMean;
  }

  private redirect(redirection: Redirection) {
    if (
      !(redirection instanceof ExternalRedirection) ||
      redirection.redirection.recommendedImplementation !==
        RECOMMENDED_IMPLEMENTATIONS.INVISIBLE_IFRAME
    ) {
      this.showInvisibleIframe.set(false);
      this.nextStepEvent.emit(redirection);
      return;
    }
    this.showInvisibleIframe.set(true);
  }

  toggleSelectedPaymentMean(paymentMean: PaymentMean): void {
    if (this.isSelectedPaymentMean(paymentMean)) {
      this.selectedPaymentMean.set(undefined);
    } else {
      this.selectedPaymentMean.set(paymentMean);
    }
  }

  isSelectedPaymentMean(paymentMean: PaymentMean): Boolean {
    return this.selectedPaymentMean() === paymentMean;
  }

  getLogoPaymentMean(paymentMean: PaymentMean): string | null {
    switch (paymentMean.type) {
      case PAYMENT_MEAN_TYPES.PAYMENT_INITIATION:
        return 'mp_picto_transfer';
      case PAYMENT_MEAN_TYPES.CARD:
        return 'mp_picto_card';
      case PAYMENT_MEAN_TYPES.PAYPAL:
        return 'mp_picto_paypal';
      case PAYMENT_MEAN_TYPES.APPLEPAY:
        return 'mp_picto_apple_pay';
      case PAYMENT_MEAN_TYPES.WERO:
        return 'mp_picto_wero';
      default:
        return null;
    }
  }

  async handleSubmit(type: PaymentMeanType) {
    if (this._alreadySubmitted()) {
      return;
    }
    window.parent.postMessage({ action: 'notify', eventType: 'paymentMeanSubmitted' }, '*');
    window.parent.postMessage({ action: 'sendType', type: type }, '*');
    this._alreadySubmitted.set(true);
    this._spinnerService.injectComponent(this.container());
    const redirection = await this._service.submitPaymentMean(this.paymentSessionHref(), type);
    this.redirect(redirection);
  }

  handleProvideBrowserData(): void {
    this._service.provideBrowserData(this.paymentSessionHref());
  }

  async invisibleIframeCallback() {
    const redirection = await this._service.collectTechnicalInformation(this.paymentSessionHref());
    this.redirect(redirection);
  }
}
