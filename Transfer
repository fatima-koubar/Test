case 'ready':
  console.log("ready received");

  if (routeAlreadyUpdated) {
    return;
  }

  routeAlreadyUpdated = true;

  const iframe = paymentComponent.getElementsByTagName('iframe')[0] as HTMLIFrameElement;

  if (!iframe) {
    break;
  }

  let url =
    environment.moneticoUrl +
    '/payment-component/payment-session/' +
    this._paymentSessionId;

  if (paymentMeanType) {
    url +=
      '?paymentMeanType=' +
      encodeURIComponent(paymentMeanType);
  }

  iframe.src = url;

  break;
