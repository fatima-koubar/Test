        result.newpos.infrastructure = this.enumsList().infrastructures?.find(pm => pm.id == result.newpos.idInfrastructure)?.value;
        result.newpos.environment = this.enumsList().environments?.find(pm => pm.id == result.newpos.idEnvironment)?.value;

