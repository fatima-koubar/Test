payment-mean.component.html

@if (isReady() && paymentMeans()) {
  <div class="mp_acc_paymtmean ei_overflowhidden">
    @for (paymentMean of paymentMeans(); track paymentMean; let pmCount = $count) {
      <div
        #overlay
        class="ei_relative"
        [class]="{'mp_acc_paymtmean_item': true, 'mp_acc_paymtmean_item_selected': isSelectedPaymentMean(paymentMean), 'mp_acc_paymtmean_item_uniq': pmCount == 1}"
      >
        @switch (paymentMean.type) {
          @case (PaymentMeanType.APPLEPAY) {
            @defer (when paymentMean.type === PaymentMeanType.APPLEPAY) {
              <pc-apple-pay
                [amount]="data().amount"
                [paymentMeanHref]="paymentMean.href"
                [hidden]="pmCount > 0 && !isSelectedPaymentMean(paymentMean)"
                (submitEvent)="handleSubmit($event)"
                [paymentSessionHref]="paymentSessionHref()"
              ></pc-apple-pay>
            }
          }
        }
      </div>
    }
  </div>
}

