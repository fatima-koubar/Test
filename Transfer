private handleResendOtpError(
  error: ClickToPaySDKPortInitiateIdentityValidationError,
): Observable<void> {
  const otpForm = this.otpForm.get('otp');

  if (!otpForm) {
    return of(void 0);
  }

  if (
    error.reason ===
    SDK_INITIATE_IDENTITY_VALIDATION_ERROR_TYPES.OTP_SEND_FAILED
  ) {
    otpForm.setErrors({
      retriesExceededError: 'plusieurs essaies',
    });
  }

  return of(void 0);
}
