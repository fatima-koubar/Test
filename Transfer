import { APP_BOOTSTRAP_LISTENER, ApplicationConfig } from '@angular/core';
import { Routes, provideRouter } from '@angular/router';
import {
  ENVIRONMENT_TOKEN,
  INTEGRATION_TYPES,
  providePaymentComponent,
} from '@r-emc1/payment-component';
import { environment } from 'src/environments/environment';
import { AppRouterComponent } from './router-component/components/router/router.component';

//@TODO: mutualiser dans i18ninitializer
import '@angular/common/locales/global/fr';
import { AppApplePayPopinComponent } from './apple-pay-popin-component/apple-pay-popin.component';
import { AppRedirectionComponent } from './redirection-component/components/redirection/redirection.component';
import { SdkTranslationsService } from './sdk-translations.service';
import { AppPaymentMeanComponent } from './payment-mean-component/components/payment-mean/payment-mean.component';

export const routes: Routes = [
  {
    path: 'payment-session/:id/:paymentMeanType',
    component: AppPaymentMeanComponent,
  },
  {
    path: 'payment-session/:id',
    component: AppRouterComponent,
  },
  {
    path: 'payment-session/:id/redirect/popin',
    component: AppRedirectionComponent,
  },
  {
    path: 'payment-session/:id/apple-pay/popin',
    component: AppApplePayPopinComponent,
  },
];

export const appConfig: ApplicationConfig = {
  providers: [
    provideRouter(routes),
    { provide: ENVIRONMENT_TOKEN, useValue: environment },
    providePaymentComponent({
      context: INTEGRATION_TYPES.PAYMENT_COMPONENT,
      onFaviconLinkLoad: () => {
        const container = document.getElementById('mainDiv');
        const height = container!.scrollHeight + 1;
        const compStyle = getComputedStyle(document.documentElement);
        window.parent.postMessage(
          {
            action: 'resize',
            height: height,
            borderRadius: compStyle.getPropertyValue('--button-borderRadius'),
          },
          '*',
        );
      },
    }),
    {
      provide: APP_BOOTSTRAP_LISTENER,
      multi: true,
      useFactory: (sdkTranslationsService: SdkTranslationsService) => {
        return () => sdkTranslationsService.init();
      },
      deps: [SdkTranslationsService],
    },
  ],
};


router.component.html: 

@if (_paymentSessionStore.initialized()) {
  @switch (_paymentSessionStore.currentView()) {
    @case (VIEW_TYPES.ERROR_VIEW) {
      <pcapp-error [data]="$any(_paymentSessionStore.data())"></pcapp-error>
    }
    @case (VIEW_TYPES.PAYMENT_MEAN_VIEW) {
      <pcapp-payment-mean
        [paymentSessionId]="_paymentSessionStore.id()"
        [data]="$any(_paymentSessionStore.data())"
        [sandbox]="_paymentSessionStore.sandbox()"
        [links]="_paymentSessionStore.hateoasLinks()"
        (nextStepEvent)="handleNextStep($event)"
      ></pcapp-payment-mean>
    }
    @case (VIEW_TYPES.SUMMARY_TICKET_VIEW) {
      <pcapp-summary-ticket (nextStepEvent)="handleNextStep($event)"></pcapp-summary-ticket>
    }
  }
}

