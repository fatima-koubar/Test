fonction, tout va bien , je peux loguer identificationRequest dans le tap . mais quand je selectionne un scenario de test, par exemple compte suspendu (mail: inacessible@test)
j'arrive pas à logguer  identificationRequest, alors que j'ai bien l'id renseigné qui est {"email":"inacessible@test"}. c'est quoi le souci ? 

identifyAcrossSchemes(id: IdentificationInput): Observable<void> {
    let identificationRequest: Channel;
    if ('email' in id) {
      identificationRequest = {
        type: CHANNEL_TYPES.EMAIL_ADDRESS,
        value: id.email,
      };
    } else {
      identificationRequest = {
        type: CHANNEL_TYPES.MOBILE_PHONE_NUMBER,
        value: id.mobile,
      };
    }
    return from(
      Promise.all(
        this._ports.map(async (port) => {
          return {
            port,
            identificationOutput: await firstValueFrom(port.identify(identificationRequest)),
          };
        }),
      ),
    ).pipe(
      tap(() => {
        console.log(identificationRequest);
        switch (identificationRequest.type) {
          case CHANNEL_TYPES.EMAIL_ADDRESS:
            return this._paymentStateStore.setValidationChannelOTP(
              this._maskingService.maskEmail(identificationRequest.value),
            );
          case CHANNEL_TYPES.MOBILE_PHONE_NUMBER:
            return this._paymentStateStore.setValidationChannelOTP(
              this._maskingService.maskPhone(identificationRequest.value),
            );
        }
      }),
      switchMap(async (outputsWithPort) => {
        const outputsWithPortPresent = outputsWithPort.filter(
          (outputWithPort) => outputWithPort.identificationOutput.consumerIsPresent,
        );

        if (outputsWithPortPresent.length === 0) {
          if (
            this._paymentStateStore.currentStep() === PaymentStep.AUTH ||
            this._paymentStateStore.currentStep() === PaymentStep.INIT
          ) {
            this._paymentStateStore.updateStep(PaymentStep.LOG_NO_CARD, 'NO_ACTIVE_CARDS');
          }
          return;
        }

        const now = Date.now();
        const latestOutputWithPort = outputsWithPortPresent.reduce((closest, outputWithPort) => {
          if (
            !(
              outputWithPort.identificationOutput as {
                consumerIsPresent: true;
                lastUsedCardTimestamp?: number;
              }
            ).lastUsedCardTimestamp
          ) {
            return closest;
          }
          if (
            Math.abs(
              now -
                (
                  outputWithPort.identificationOutput as {
                    consumerIsPresent: true;
                    lastUsedCardTimestamp?: number;
                  }
                ).lastUsedCardTimestamp!,
            ) <
            Math.abs(
              now -
                ((
                  closest.identificationOutput as {
                    consumerIsPresent: true;
                    lastUsedCardTimestamp?: number;
                  }
                ).lastUsedCardTimestamp ?? 0),
            )
          ) {
            closest = outputWithPort;
          }
          return closest;
        }, outputsWithPortPresent[0]);

        this.setSelectedPort(latestOutputWithPort.port);
        return firstValueFrom(this.startIdentificationValidation(identificationRequest.type));
      }),
    );
  }
