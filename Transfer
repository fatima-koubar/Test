addPos():void {

    let data = {
      enums: this.enumsList
    }

    const dialogRef = this.dialog.open(EditPosComponent, {
      enterAnimationDuration: '0ms',
      exitAnimationDuration: '0ms',
      data: data
    });

    dialogRef.afterClosed().subscribe((result) => {
      if(result && result.action == 'add')
      {
        if(!this.isPosExist(result.pos))
        {
          result.pos.persoId = this.persoId;
          result.pos.idPaymentMethod = result.pos.paymentMethod;
          result.pos.idLanguage = 4; // FR by default
          result.pos.id = 0;

          if (result.pos.infrastructure === 1) {
            this.infrastructure = [1, 2]; // DEV(VM) or SIT (duplicate POS)
          } else if (result.pos.infrastructure === 4) {
            this.infrastructure = [4, 5]; // PROD1(LIL) or PROD1SEC(SXB) (duplicate POS)
          } else {
            this.infrastructure = [result.pos.infrastructure];
          }

          this.infrastructure.forEach((i) => {
            result.pos.idInfrastructure = i;

              this.environments.forEach((e) => { // duplicate POS for live and sandbox
                result.pos.idEnvironment = e;
            

                this.posExtService.postPos(result.pos).pipe(takeUntilDestroyed(this.destroyRef)).subscribe(() => {
                  this.updateData();
                });
              })
          })
        } else {
          this.showPOSAlreadyExistSnackBar();
        }
      }
    });
  } 


  isPosExist(pos: POS): Boolean
  {
    let isPosExist = false;
    this.posListData.forEach(p => {
      if(p.id == pos.id || 
        (p.infrastructure === pos.infrastructure && p.posId === pos.posId) ||
        (p.idInfrastructure === pos.infrastructure && p.posId === pos.posId)
      )
      {
        isPosExist =  true;
      }
    });    
    return isPosExist;
  }

