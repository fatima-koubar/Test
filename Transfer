[HttpGet("filterBy")]
public ActionResult<List<Pos>> GetFilteredPosBy([FromQuery]
    string persoId,
    List<int> infrastructures,
    List<int> environments,
    List<int> paymentMethods)
{
    PosDAO posDAO = new();
    List<Pos> posList = posDAO.GetPosFilteredBy(
        persoId,
        infrastructures,
        environments,
        paymentMethods);

    if (posList.Count < 0)
    {
        return NotFound();
    }
    else
    {
        return Ok(posList);
    }
}
