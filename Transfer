async ngOnInit() {
    if (this._integrationType == INTEGRATION_TYPES.PAYMENT_COMPONENT) {
      window.parent.postMessage({ action: 'ready' }, '*');
      window.addEventListener('message', async (event) => {
        if (event.data.action === 'sendPaymentMeanType' && event.data.paymentMeanType) {
          this.hateoasLinks.set(this.getPaymentMeanByWrapperId(event.data.paymentMeanType));
          this._document.body.classList.add('mono');
        } else {
          this.hateoasLinks.set(this.links());
        }
        await this.initiate();
      });
    } else {
      this.hateoasLinks.set(this.links());
      await this.initiate();
    }
  }
