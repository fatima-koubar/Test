@if (isReady() && paymentMeans()) {
  <div class="mp_acc_paymtmean ei_overflowhidden">
    <!-- Item d'accordéon -->
    @for (paymentMean of paymentMeans(); track paymentMean; let pmCount = $count) {
      <div
        #overlay
        class="ei_relative"
        [class]="{'mp_acc_paymtmean_item': true, 'mp_acc_paymtmean_item_selected': isSelectedPaymentMean(paymentMean), 'mp_acc_paymtmean_item_uniq': pmCount == 1}"
      >
        <span role="heading" aria-level="3" class="heading">
          @if ($count > 1) {
            <button
              #paymentMeanButton
              type="button"
              (click)="toggleSelectedPaymentMean(paymentMean)"
              [attr.aria-expanded]="isSelectedPaymentMean(paymentMean)"
              [attr.aria-disabled]="isSelectedPaymentMean(paymentMean)"
              class="mp_acc_paymtmean_button g"
              [class]="{'mp_acc_paymtmean_item_collapsed': !isSelectedPaymentMean(paymentMean)}"
              [ngStyle]="{'--btn-hover': hoverColor()}"
              [attr.id]="paymentMean.id"
            >
              <span
                class="mp_acc_paymtmean_header_b mp_acc_paymtmean_button_picto_choice"
                aria-hidden="true"
              ></span>
              <span class="mp_acc_paymtmean_button_label">
                {{ paymentMean.type | paymentMeanText: $any(paymentMean).sctType | translate }}
              </span>

              @if (paymentMean.type === PaymentMeanType.CARD) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('card/card.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.CARD' | translate"
                  />
                </span>
              } @else if (paymentMean.type === PaymentMeanType.PAYPAL) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('picto/logo_paypal.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.PAYPAL' | translate"
                  />
                </span>
              } @else if (paymentMean.type === PaymentMeanType.WERO) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('picto/logo_wero.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.WERO' | translate"
                  />
                </span>
              } @else if (paymentMean.type === PaymentMeanType.APPLEPAY) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('picto/logo_apple_pay.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.APPLE_PAY' | translate"
                  />
                </span>
              } @else if (getLogoPaymentMean(paymentMean) != null) {
                <span
                  class="mp_acc_paymtmean_header_a mp_acc_paymtmean_button_container_img"
                  [class]="getLogoPaymentMean(paymentMean)"
                  aria-hidden="true"
                ></span>
              }
            </button>
          } @else {
            <div class="mp_acc_paymtmean_button g">
              <span class="mp_acc_paymtmean_button_label">
                {{ paymentMean.type | paymentMeanText: $any(paymentMean).sctType | translate }}
              </span>

              @if (paymentMean.type === PaymentMeanType.CARD) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('card/card.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.CARD' | translate"
                  />
                </span>
              } @else if (paymentMean.type === PaymentMeanType.PAYPAL) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('picto/logo_paypal.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.PAYPAL' | translate"
                  />
                </span>
              } @else if (paymentMean.type === PaymentMeanType.WERO) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('picto/logo_wero.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.WERO' | translate"
                  />
                </span>
              } @else if (paymentMean.type === PaymentMeanType.APPLEPAY) {
                <span class="mp_acc_paymtmean_button_container_img">
                  <img
                    [src]="_urlService.getAssetsImgURL('picto/logo_apple_pay.svg')"
                    [alt]="'PAYMENT_MEANS.CARD.IMAGES.APPLE_PAY' | translate"
                  />
                </span>
              } @else if (getLogoPaymentMean(paymentMean) != null) {
                <span
                  class="mp_acc_paymtmean_header_a mp_acc_paymtmean_button_container_img"
                  [class]="getLogoPaymentMean(paymentMean)"
                  aria-hidden="true"
                ></span>
              }
            </div>
          }
        </span>

        @switch (paymentMean.type) {
          @case (PaymentMeanType.PAYMENT_INITIATION) {
            @defer (when paymentMean.type === PaymentMeanType.PAYMENT_INITIATION) {
              <pc-payment-initiation
                [paymentMeanHref]="paymentMean.href"
                [hidden]="pmCount > 0 && !isSelectedPaymentMean(paymentMean)"
                [amount]="data().amount"
                (submitEvent)="handleSubmit($event)"
              ></pc-payment-initiation>
            }
          }

          @case (PaymentMeanType.CARD) {
            @defer (when paymentMean.type === PaymentMeanType.CARD) {
              <pc-card
                [paymentMeanHref]="paymentMean.href"
                [hidden]="pmCount > 0 && !isSelectedPaymentMean(paymentMean)"
                [amount]="data().amount"
                (submitEvent)="handleSubmit($event)"
                (provideBrowserDataEvent)="handleProvideBrowserData()"
              ></pc-card>
            }
          }

          @case (PaymentMeanType.PAYPAL) {
            @defer (when paymentMean.type === PaymentMeanType.PAYPAL) {
              <pc-paypal-button
                [hidden]="pmCount > 0 && !isSelectedPaymentMean(paymentMean)"
                [amount]="data().amount"
                (submitEvent)="handleSubmit($event)"
              ></pc-paypal-button>
            }
          }

          @case (PaymentMeanType.WERO) {
            @defer (when paymentMean.type === PaymentMeanType.WERO) {
              @if (isSelectedPaymentMean(paymentMean)) {
                <pc-wero-button
                  [hidden]="pmCount > 0 && !isSelectedPaymentMean(paymentMean)"
                  [amount]="data().amount"
                  (submitEvent)="handleSubmit($event)"
                ></pc-wero-button>
              }
            }
          }

          @case (PaymentMeanType.APPLEPAY) {
            @defer (when paymentMean.type === PaymentMeanType.APPLEPAY) {
              <pc-apple-pay
                [amount]="data().amount"
                [paymentMeanHref]="paymentMean.href"
                [hidden]="pmCount > 0 && !isSelectedPaymentMean(paymentMean)"
                (submitEvent)="handleSubmit($event)"
                [paymentSessionHref]="paymentSessionHref()"
              ></pc-apple-pay>
            }
          }
        }
      </div>
    }
  </div>
}

@if (showInvisibleIframe()) {
  <pc-invisible-iframe
    [paymentSessionId]="paymentSessionId()"
    (iframeProcessDoneEvent)="invisibleIframeCallback()"
  ></pc-invisible-iframe>
}



