PaymentSessionStore = signalStore(
  { providedIn: 'root' },
  withState<PaymentSessionStoreState>(() => ({
    ...initialState,
    integrationType: inject(PAYMENT_SESSION_CONTEXT),
  })),
  withMethods(
    (
      store,
    ) => ({
      setSession(session: Omit<PaymentSessionDTO, 'integration_type'>) {
        patchState(store, {
          hateoasLinks: Hateoas.create(session._links)
        });
      },
      setPaymentMeans(hateoasPaymentMeans: Array<HateoasPaymentMean>) {
        patchState(store, {
          hateoasLinks: Hateoas.create({
            ...store.hateoasLinks().asProps(),
            payment_means: hateoasPaymentMeans,
          }),
        });
      },
...)
