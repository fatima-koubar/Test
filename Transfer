import { ComponentFixture, TestBed, fakeAsync, tick } from '@angular/core/testing';
import { Component } from '@angular/core';
import { NO_ERRORS_SCHEMA } from '@angular/core';
import { of } from 'rxjs';

import { PaymentMeanComponent } from './payment-mean.component';
import { PaymentMeanService } from '../../payment-mean.service';
import { UrlService } from '../../../core/services/url.service';
import { SpinnerService } from '../../../spinner/spinner.service';
import { PAYMENT_SESSION_CONTEXT } from '../../../../public-api';
import { INTEGRATION_TYPES } from '../../../domain';
import { Hateoas } from '../../../domain';
import { TranslateService } from '@ngx-translate/core';

/* -----------------------------
   MOCK CHILD COMPONENTS
------------------------------ */

@Component({
  selector: 'pc-card',
  template: '',
  standalone: true,
})
class MockCardComponent {}

@Component({
  selector: 'pc-payment-initiation',
  template: '',
  standalone: true,
})
class MockPaymentInitComponent {}

@Component({
  selector: 'pc-paypal-button',
  template: '',
  standalone: true,
})
class MockPaypalComponent {}

@Component({
  selector: 'pc-apple-pay',
  template: '',
  standalone: true,
})
class MockApplePayComponent {}

@Component({
  selector: 'pc-wero-button',
  template: '',
  standalone: true,
})
class MockWeroComponent {}

@Component({
  selector: 'pc-invisible-iframe',
  template: '',
  standalone: true,
})
class MockIframeComponent {}

/* -----------------------------
   TEST SUITE
------------------------------ */

describe('PaymentMeanComponent', () => {
  let component: PaymentMeanComponent;
  let fixture: ComponentFixture<PaymentMeanComponent>;

  let paymentMeanServiceStub: jasmine.SpyObj<PaymentMeanService>;
  let urlServiceStub: jasmine.SpyObj<UrlService>;
  let spinnerServiceStub: jasmine.SpyObj<SpinnerService>;

  const mockLinks: Hateoas = {
    self: { href: '/payment-session/123' },
    paymentMeans: [
      { type: 'card', href: '/card' },
      { type: 'paypal', href: '/paypal' },
    ],
  } as any;

  beforeEach(async () => {
    paymentMeanServiceStub = jasmine.createSpyObj('PaymentMeanService', [
      'applePayloadScript',
      'submitPaymentMean',
      'collectTechnicalInformation',
      'provideBrowserData',
    ]);

    paymentMeanServiceStub.applePayloadScript.and.resolveTo();
    paymentMeanServiceStub.submitPaymentMean.and.resolveTo({} as any);
    paymentMeanServiceStub.collectTechnicalInformation.and.resolveTo({} as any);

    urlServiceStub = jasmine.createSpyObj('UrlService', ['getAssetsImgURL']);
    spinnerServiceStub = jasmine.createSpyObj('SpinnerService', ['injectComponent']);

    await TestBed.configureTestingModule({
      imports: [
        PaymentMeanComponent,

        // mocked children
        MockCardComponent,
        MockPaymentInitComponent,
        MockPaypalComponent,
        MockApplePayComponent,
        MockWeroComponent,
        MockIframeComponent,
      ],
      providers: [
        {
          provide: PAYMENT_SESSION_CONTEXT,
          useValue: INTEGRATION_TYPES.PAYMENT_PAGE,
        },
        { provide: PaymentMeanService, useValue: paymentMeanServiceStub },
        { provide: UrlService, useValue: urlServiceStub },
        { provide: SpinnerService, useValue: spinnerServiceStub },

        // translate mock
        {
          provide: TranslateService,
          useValue: {
            instant: (k: string) => k,
            get: () => of(''),
            use: () => of(null),
            stream: () => of(''),
          },
        },
      ],
      schemas: [NO_ERRORS_SCHEMA],
    }).compileComponents();

    fixture = TestBed.createComponent(PaymentMeanComponent);
    component = fixture.componentInstance;
  });

  /* -----------------------------
     BASIC CREATION TEST
  ------------------------------ */

  it('should create', () => {
    fixture.componentRef.setInput('data', { amount: 100 } as any);
    fixture.componentRef.setInput('links', mockLinks);
    fixture.componentRef.setInput('paymentSessionId', '123');

    fixture.detectChanges();

    expect(component).toBeTruthy();
  });

  /* -----------------------------
     INIT TEST (CORE LOGIC ONLY)
  ------------------------------ */

  it('should initialize payment means', fakeAsync(() => {
    fixture.componentRef.setInput('data', { amount: 100 } as any);
    fixture.componentRef.setInput('links', mockLinks);
    fixture.componentRef.setInput('paymentSessionId', '123');

    fixture.detectChanges();
    tick();

    expect(component.paymentMeans().length).toBe(2);
    expect(component.paymentSessionHref()).toBe('/payment-session/123');
    expect(component.isReady()).toBeTrue();
  }));
});
