const OPT_SEND_FAILED_COUNTER = 5;

export class SandboxSDKAdapter extends ClickToPaySDKPort {
  private counter = 0;

  completeIdentityValidation(
    input: IdentificationValidationCompletionInput,
    rememberMe: boolean,
  ): Observable<IdentificationValidationCompletionOutput> {
    const value = input.value as OTPValues;

    if (!Object.values(OTP_VALUES).includes(value)) {
      this.counter++;
      if (this.counter > OPT_SEND_FAILED_COUNTER) {
        this.counter = 0;
        return throwError(
          () =>
            new ClickToPaySDKPortCompleteIdentityValidationError(
              SDK_COMPLETE_IDENTITY_VALIDATION_ERROR_TYPES.RETRIES_EXCEEDED,
              this.getType(),
            ),
        );
      }
      return throwError(
        () =>
          new ClickToPaySDKPortCompleteIdentityValidationError(
            SDK_COMPLETE_IDENTITY_VALIDATION_ERROR_TYPES.CODE_INVALID,
            this.getType(),
          ),
      );
    }
  }
}
