export class PaymentMeanComponent implements OnInit {
  readonly data = input.required<PaymentMeanData>();
  readonly links = input.required<Hateoas>();
  readonly paymentSessionId = input.required<string>();
  readonly hateoasLinks: WritableSignal<Hateoas> = signal<Hateoas>({} as Hateoas);

  readonly nextStepEvent = output<Redirection>();

  private readonly _service = inject(PaymentMeanService);
  private readonly _spinnerService = inject(SpinnerService);
  protected readonly _urlService = inject(UrlService);
  private readonly _integrationType = inject(PAYMENT_SESSION_CONTEXT);
  private readonly _document = inject(DOCUMENT);

  private readonly _alreadySubmitted = signal<boolean>(false);
  readonly selectedPaymentMean = signal<PaymentMean | undefined>(undefined);
  readonly showInvisibleIframe = signal<boolean>(false);
  readonly isReady = signal<boolean>(false);

  readonly paymentMeans: WritableSignal<PaymentMean[]> = signal<PaymentMean[]>([]);
  readonly paymentSessionHref: WritableSignal<string> = signal<string>('');

  readonly container = viewChild.required('overlay', { read: ViewContainerRef });

  readonly PaymentMeanType = PAYMENT_MEAN_TYPES;

  async ngOnInit(): Promise<void> {
    this.hateoasLinks.set(this.links());
    await this.initiate();
  }

  private async initiate(): Promise<void> {
    this.paymentMeans.set(
      (this.hateoasLinks().paymentMeans ?? []).map((pm) =>
        createPaymentMean(this.getPaymentMeanProps(pm)),
      ),
    );

    this.paymentSessionHref.set(this.hateoasLinks().self.href);

    await this._service.applePayloadScript(this.paymentMeans(), this.links());
    this.isReady.set(true);
  }

  private getPaymentMeanProps(hateoasPaymentMean: HateoasPaymentMean) {
    const basePaymentMean = {
      type: hateoasPaymentMean.type,
      href: hateoasPaymentMean.href,
    };

    if (hateoasPaymentMean instanceof HateoasPaymentMeanPaymentInitiation) {
      return {
        ...basePaymentMean,
        sctType: hateoasPaymentMean.sctType,
      };
    }
    if (hateoasPaymentMean instanceof HateoasPaymentMeanApplePay) {
      return {
        ...basePaymentMean,
        merchantIdentifier: hateoasPaymentMean.merchantIdentifier,
      };
    }
    return basePaymentMean;
  }
 }
 
