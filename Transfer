import { Component, DestroyRef, OnInit, inject, DOCUMENT } from '@angular/core';
import {
  CompleteRedirection,
  ExternalRedirection,
  FrictionLessRedirection,
  PAYMENT_STATES,
  Redirection,
  RouterComponent,
  VIEW_TYPES,
} from '@r-emc1/payment-component';
import { takeUntilDestroyed, toObservable } from '@angular/core/rxjs-interop';
import { AppErrorComponent } from 'src/app/error-component/components/error/error.component';
import { AppPaymentMeanComponent } from 'src/app/payment-mean-component/components/payment-mean/payment-mean.component';
import { AppSummaryTicketComponent } from 'src/app/summary-ticket-component/components/summary-ticket/summary-ticket.component';

import { filter, take, tap } from 'rxjs';
@Component({
  selector: 'pcapp-router',
  templateUrl: './router.component.html',
  standalone: true,
  imports: [AppErrorComponent, AppPaymentMeanComponent, AppSummaryTicketComponent],
})
export class AppRouterComponent extends RouterComponent implements OnInit {
  private readonly _document = inject(DOCUMENT);
  private readonly _destroyRef = inject(DestroyRef);

  private readonly _paymentSessionState$ = toObservable(this._paymentSessionStore.state);
  private readonly _paymentSessionView$ = toObservable(this._paymentSessionStore.currentView);

  VIEW_TYPES = VIEW_TYPES;

  ngOnInit(): void {
    this._document.body.classList.add('component-integration');

    this._paymentSessionState$
      .pipe(
        filter((state) => state === PAYMENT_STATES.COMPLETED),
        tap(() =>
          window.parent.postMessage(
            { action: 'notify', eventType: 'paymentSessionFinalized' },
            '*',
          ),
        ),
        takeUntilDestroyed(this._destroyRef),
      )
      .subscribe();

    this._paymentSessionView$
      .pipe(
        filter((view) => view === VIEW_TYPES.REDIRECTION_VIEW),
        tap(() =>
          window.parent.postMessage(
            { action: 'create', url: window.location.href + '/redirect/popin' },
            '*',
          ),
        ),
        takeUntilDestroyed(this._destroyRef),
        take(1),
      )
      .subscribe();
  }

  override handleNextStep(nextStep: Redirection): void {
    window.parent.postMessage({ action: 'notify', eventType: 'paymentMethodSubmitted' }, '*');
    if (nextStep instanceof ExternalRedirection || nextStep instanceof CompleteRedirection) {
      window.parent.postMessage(
        { action: 'create', url: window.location.href + '/redirect/popin' },
        '*',
      );
      return;
    }
    if (!(nextStep instanceof FrictionLessRedirection)) {
      return;
    }
    super.handleNextStep(nextStep);
  }
}



