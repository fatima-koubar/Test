identify(channel: Channel): Observable<IdentificationOutput> {
    switch (channel.value as LogginValues | '') {
      case LOGGIN_VALUES.ACCOUNT_INACCESSIBLE_INPUT:
        return throwError(
          () =>
            new ClickToPaySDKPortIdentityLookupError(
              SDK_IDENTITY_LOOKUP_ERROR_TYPES.ACCOUNT_INACCESSIBLE,
              this.getType(),
            ),
        );
      case LOGGIN_VALUES.FRAUD:
        return throwError(
          () =>
            new ClickToPaySDKPortIdentityLookupError(
              SDK_IDENTITY_LOOKUP_ERROR_TYPES.FRAUD,
              this.getType(),
            ),
        );
      case LOGGIN_VALUES.DEFAULT_ERROR:
        return throwError(
          () =>
            new ClickToPaySDKPortIdentityLookupError(
              SDK_IDENTITY_LOOKUP_ERROR_TYPES.CONSUMER_ID_MISSING,
              this.getType(),
            ),
        );
      case '':
        return throwError(
          () =>
            new ClickToPaySDKPortIdentityLookupError(
              SDK_IDENTITY_LOOKUP_ERROR_TYPES.CONSUMER_ID_MISSING,
              this.getType(),
            ),
        );
      default:
        if (
          channel.value.replace(/(\s|\-*)/g, '') ===
          LOGGIN_VALUES.WRONG_IDENTIFICATION_INPUT.replace(/(\s|\-*)/g, '')
        ) {
          return of<IdentificationOutput>({
            consumerIsPresent: false,
          }).pipe(delay(500));
        }
        this._channelMemo.set({ ...channel, value: channel.value });
        return of<IdentificationOutput>({
          consumerIsPresent: true,
        }).pipe(delay(500));
    }
  }
