  onSearchChanged(event: { searchText: string, filterBy: 'posId' | 'tag'}): void {
    const text = event.searchText.toLowerCase();

    if (!text) {
      this.searchedItems.set([...this.posListData()]);
      return;
    }

    this.searchedItems.set(this.posListData().filter(item => {
      if (event.filterBy === 'posId') {
        return item.posId.toLowerCase().includes(text);
      } 
      if (event.filterBy === 'tag') {
        return item.tags.some((tag: any) =>
          tag.toLowerCase().includes(text)
        );
      }
      return false;
    }));
    this.clearFilters();
  }

