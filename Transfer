  public List<Pos> GetPosFilteredBy(
    string persoId,
    string? infrastructure,
    string? environment,
    string? paymentMethod
    )
{
    PosDAO posDAO = new();

    var infrastructures = JsonConvert.DeserializeObject<List<int>>(infrastructure);
    var environments = JsonConvert.DeserializeObject<List<int>>(environment);
    var paymentMethods = JsonConvert.DeserializeObject<List<int>>(paymentMethod);

    var query = posDAO._context.Pos
        .Include(p => p.environment)
        .Include(p => p.infrastructure)
        .Include(p => p.language)
        .Include(p => p.payment_method)
        .AsQueryable();

    if (!string.IsNullOrEmpty(persoId))
    {
        query = query.Where(p => p.persoId == persoId);
    }

    if (environments != null && environments.Any())
    {
        query = query.Where(p => environments.Contains(p.idEnvironment));
        System.Diagnostics.Debug.WriteLine(query.ToQueryString());
    }

    if (infrastructures != null && infrastructures.Any())
    {
        query = query.Where(p => infrastructures.Contains(p.idInfrastructure));
    }

    if (paymentMethods != null && paymentMethods.Any())
    {
        query = query.Where(p => paymentMethods.Contains(p.idPaymentMethod));
    }

    System.Diagnostics.Debug.WriteLine(query.ToQueryString());

    return query
        .Select(pos => (Pos)pos)
        .ToList();
}

et dans le controller j'ai: 
[HttpGet("filterBy")]
public ActionResult<List<Pos>> GetFilteredPosBy(
    [FromQuery] string persoId,
    [FromQuery] string? infrastructure,
    [FromQuery] string? environment,
    [FromQuery] string? paymentMethod)
{
    PosDAO posDAO = new();

    var posList = posDAO.GetPosFilteredBy(persoId, infrastructure, environment, paymentMethod);

    if (posList == null || !posList.Any())
    {
        return NotFound();
    }

    return Ok(posList);
}

