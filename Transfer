addPos(): void {
  const dialogRef = this.dialog.open(EditPosComponent, {
    enterAnimationDuration: '0ms',
    exitAnimationDuration: '0ms',
    data: { enums: this.enumsList }
  });

  dialogRef.afterClosed()
    .pipe(takeUntilDestroyed(this.destroyRef))
    .subscribe(result => {
      if (!result || result.action !== 'add') return;

      const basePos = {
        ...result.pos,
        persoId: this.persoId,
        idPaymentMethod: result.pos.paymentMethod,
        idLanguage: 4,
        id: 0
      };

      const infrastructures = this.getInfrastructures(basePos.infrastructure);

      let alreadyExists = false;

      const requests = infrastructures.flatMap(infra => {

        if (this.isPosExist(basePos, infra)) {
          alreadyExists = true;
          return []; // skip
        }

        return this.environments.map(env => ({
          ...basePos,
          idInfrastructure: infra,
          idEnvironment: env
        }));
      });

      if (alreadyExists) {
        this.showPOSAlreadyExistSnackBar();
      }

      if (requests.length === 0) return;

      from(requests).pipe(
        mergeMap(pos =>
          this.posExtService.postPos(pos)
        ),
        takeUntilDestroyed(this.destroyRef)
      ).subscribe({
        next: () => {},
        complete: () => this.updateData()
      });
    });
}


getInfrastructures(infra: number): number[] {
  switch (infra) {
    case 1: return [1, 2]; // DEV + SIT
    case 4: return [4, 5]; // PROD + SEC
    default: return [infra];
  }
}

isPosExist(pos: POS, infrastructure: number): boolean {
  return this.posListData.some(p =>
    p.posId === pos.posId &&
    (p.idInfrastructure === infrastructure || p.infrastructure === infrastructure)
  );
}
