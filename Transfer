[HttpGet("filterBy")]
public ActionResult<List<Pos>> GetFilteredPosBy([FromQuery]
    string persoId,
    List<int> infrastructures,
    List<int> environments,
    List<int> paymentMethods)
{
    PosDAO posDAO = new();
    List<Pos> posList = posDAO.GetPosFilteredBy(
        persoId,
        infrastructures,
        environments,
        paymentMethods);

    if (posList.Count < 0)
    {
        return NotFound();
    }
    else
    {
        return Ok(posList);
    }
}


[HttpGet("filterBy")]
public ActionResult<List<Pos>> GetFilteredPosBy(
    [FromQuery] string persoId,
    [FromQuery] List<int>? infrastructures,
    [FromQuery] List<int>? environments,
    [FromQuery] List<int>? paymentMethods)
{
    PosDAO posDAO = new();

    var posList = posDAO.GetPosFilteredBy(
        persoId,
        infrastructures,
        environments,
        paymentMethods);

    if (posList == null || !posList.Any())
    {
        return NotFound();
    }

    return Ok(posList);
}
